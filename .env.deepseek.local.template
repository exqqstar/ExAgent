# Local DeepSeek config for ExAgent.
# Copy these lines into .env.deepseek.local and fill OPENAI_API_KEY locally.

export OPENAI_BASE_URL="https://api.deepseek.com"
export OPENAI_API_KEY="paste-your-deepseek-api-key-here"
export OPENAI_MODEL="deepseek-v4-pro"

# Supported by current ExAgent implementation: auto, low, medium, high.
# For DeepSeek thinking-mode smoke tests, start with high.
export EXAGENT_THINKING_MODE="high"

# Keep policy off for smoke/benchmark runs so approvals do not block.
export EXAGENT_POLICY_MODE="off"
